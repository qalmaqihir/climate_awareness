# Copy to .env (not committed) and fill in real values.
# On VPS, .env lives at ~/docker/apps/climate_awareness/climate_awareness/.env (chmod 600)

# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_DB=climate_gb
POSTGRES_USER=climate_gb
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=changeme

# ─── Application ──────────────────────────────────────────────────────────
# Public URL where NPM serves the app
NEXTAUTH_URL=https://climate-gb.example.org
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=changeme

# Connection strings the web/worker containers use (already composed in docker-compose.yml,
# only set here for local dev outside Docker)
DATABASE_URL=postgres://climate_gb:changeme@127.0.0.1:5432/climate_gb
REDIS_URL=redis://127.0.0.1:6379

# Comma-separated list of emails allowed to sign in as admin
ADMIN_EMAILS=admin@example.org

# ─── RAG AI — required for /ask page ─────────────────────────────────────
# LLM inference via OpenRouter (free tier: google/gemma-4-26b-a4b-it:free)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Embedding model: Jina AI v3 (free 1M tokens/day)
# Get key at: https://jina.ai
# Without this: embedding_v1 stays NULL → RAG citations will not appear
JINA_API_KEY=

# Optional: override default daily RAG question limit per IP (default: 20)
AGENT_RATE_LIMIT=20

# ─── External APIs ────────────────────────────────────────────────────────
# Open-Meteo — no key required
# Meta oEmbed — no token required (tokenless since Jun 15 2026)

# ─── Security ─────────────────────────────────────────────────────────────
# Permanent IP ban list — comma-separated, checked at middleware edge level.
# Example: BLOCKED_IPS=1.2.3.4,5.6.7.8
BLOCKED_IPS=

# ─── Telegram Bot (Phase 2.B) ────────────────────────────────────────────────
# Create bot via @BotFather, then register webhook:
#   curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#        -H "Content-Type: application/json" \
#        -d '{"url":"https://<domain>/api/telegram/webhook","secret_token":"<SECRET>"}'
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# ─── SMS Notifications (Phase 2.D) ───────────────────────────────────────────
# Twilio account — sign up at https://twilio.com
# Pakistan delivery works via standard international SMS routes (~$0.008/SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Phase 2 (leave blank until needed) ──────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ─── Backups (Phase 0.12) ─────────────────────────────────────────────────
# Choose one destination
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
# OR
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
